*.tmp
*.temp
*.bak
*.backup
*.old
.cache-loader/
.eslintcache
.stylelintcache
.prettiercache
.turbo
.parcel-cache
vite.config.local.*
tailwind.config.local.*
.env.local.*
report.html
bundle-stats.html
stats.html
.scannerwork/
.sonar/
*.pid
*.seed
*.pid.lock
.npm
.node_repl_history
.yarn-integrity
.serverless/
.fusebox/
.dynamodb/
.tern-port
.vscode-test
)
